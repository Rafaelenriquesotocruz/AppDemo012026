<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8">
    <title>AppTrip - Inicio</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .card-img-top {
            height: 200px;
            object-fit: cover;
        }
        .jumbotron {
            background-color: #f8f9fa;
            padding: 2rem;
            border-radius: 0.5rem;
        }
    </style>
</head>
<body>
    <div class="container mt-4">

        <div class="jumbotron mb-4">
            <h1 class="display-4" th:text="${mensaje1}">¡Bienvenido a AppTrip!</h1>
            <p class="lead">Gestiona tus viajes y categorías de manera fácil y rápida.</p>
            <hr class="my-4">
            <p>Accede a las opciones de administración:</p>
            <div class="d-flex gap-3">
                <a th:href="@{/trips/list}" class="btn btn-primary btn-lg">Ver Viajes</a>
                <a th:href="@{/categorias/index}" class="btn btn-success btn-lg">Ver Categorías</a>
            </div>
        </div>
        

        <h2 class="mb-4">Viajes Destacados</h2>
        
        <div th:if="${viajes != null and !viajes.empty}">
            <div class="row">
                <div class="col-md-4 mb-4" th:each="t : ${viajes}">
                    <div class="card h-100 shadow-sm">
                        <img th:src="@{/images/{img}(img=${t.imagen})}" 
                             class="card-img-top" 
                             alt="Imagen del viaje"
                             onerror="this.src='https://via.placeholder.com/300x200?text=Sin+Imagen'"/>
                        <div class="card-body">
                            <h5 class="card-title" th:text="${t.nombre}">Nombre del Viaje</h5>
                            <p class="card-text" th:text="${t.descripcion}">Descripción del viaje</p>
                            <p class="card-text">
                                <strong>Costo:</strong> <span th:text="${'$' + t.costo}"></span><br/>
                                <strong>Categoría:</strong> 
                                <span th:text="${t.categoria != null ? t.categoria.nombre : 'Sin categoría'}"></span><br/>
                                <strong>Destacado:</strong>
                                <span th:if="${t.destacado == 1}" class="badge bg-success">Destacado</span>
                                <span th:unless="${t.destacado == 1}" class="badge bg-secondary">Normal</span>
                            </p>
                            <a th:href="@{/trips/view/{id}(id=${t.id})}" class="btn btn-primary">Ver más</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div th:if="${viajes == null or viajes.empty}" class="alert alert-info">
            No hay viajes registrados. 
            <a th:href="@{/trips/create}" class="alert-link">Crea tu primer viaje</a>
        </div>
        
        <hr class="mt-4">
        <footer class="text-center mt-4">
            <p>© 2026 TripApp, Inc. | WebApp - <strong>Términos - Privacidad</strong></p>
        </footer>
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>