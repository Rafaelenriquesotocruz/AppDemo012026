<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8">
    <title>AppTrip - Inicio</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .card {
            transition: transform 0.2s;
            margin-bottom: 20px;
        }
        .card:hover {
            transform: scale(1.02);
        }
        .card-img-top {
            height: 160px;
            object-fit: cover;
        }
        .card-text {
            font-size: 0.9rem;
            color: #6c757d;
        }
        .btn-sm-custom {
            padding: 5px 15px;
            font-size: 0.8rem;
        }
        .jumbotron-compact {
            padding: 1.5rem;
            margin-bottom: 1.5rem;
        }
        h1.display-4 {
            font-size: 2rem;
        }
        h2 {
            font-size: 1.5rem;
            margin-bottom: 1rem;
        }
        .container {
            max-width: 1200px;
        }
    </style>
</head>
<body>
    <div class="container mt-3">

        <div class="bg-light p-3 rounded jumbotron-compact">
            <h1 class="display-4">¡Bienvenido a AppTrip!</h1>
            <p class="lead">Gestiona tus viajes y categorías de manera fácil y rápida.</p>
            <hr class="my-2">
            <div class="d-flex gap-2">
                <a th:href="@{/trips/list}" class="btn btn-primary">Ver Viajes</a>
                <a th:href="@{/categorias/index}" class="btn btn-success">Ver Categorías</a>
            </div>
        </div>
        

        <h2>Viajes Destacados</h2>
        
        <div th:if="${viajes != null and !viajes.empty}">
            <div class="row">
                <div class="col-md-4 col-sm-6 mb-3" th:each="t : ${viajes}">
                    <div class="card h-100 shadow-sm">
                        <img th:src="@{/images/{img}(img=${t.imagen})}" 
                             class="card-img-top" 
                             th:alt="${t.nombre}"
                             onerror="this.src='https://via.placeholder.com/300x160?text=Sin+Imagen'"/>
                        <div class="card-body">
                            <h5 class="card-title" th:text="${t.nombre}">Viaje</h5>
                            <p class="card-text" th:text="${t.descripcion != null ? t.descripcion.length() > 80 ? t.descripcion.substring(0,80) + '...' : t.descripcion : 'Sin descripción'}">Descripción</p>
                            <p class="card-text mb-1">
                                <strong>$<span th:text="${t.costo}"></span></strong> | 
                                <span th:text="${t.categoria != null ? t.categoria.nombre : 'Sin categoría'}"></span>
                            </p>
                            <a th:href="@{/trips/view/{id}(id=${t.id})}" class="btn btn-primary btn-sm-custom">Ver más</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div th:if="${viajes == null or viajes.empty}" class="alert alert-info">
            No hay viajes registrados. <a th:href="@{/trips/create}">Crea tu primer viaje</a>
        </div>
        
        <footer class="text-center mt-4 text-muted">
            <hr>
            <small>© 2026 TripApp, Inc. | WebApp - Términos - Privacidad</small>
        </footer>
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>