<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8">
    <title>AppTrip - Inicio</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <div class="container mt-4">
        <div class="jumbotron bg-light p-5 rounded">
            <h1 class="display-4" th:text="${mensaje1}">¡Bienvenido a AppTrip!</h1>
            <p class="lead">Gestiona tus viajes y categorías de manera fácil y rápida.</p>
            <hr class="my-4">
            <p>Accede a las opciones de administración:</p>
            <div class="d-flex gap-3">
                <a th:href="@{/trips/list}" class="btn btn-primary btn-lg">Ver Viajes</a>
                <a th:href="@{/categorias/index}" class="btn btn-success btn-lg">Ver Categorías</a>
            </div>
        </div>
        
        <div class="mt-5">
            <h2>Viajes Destacados</h2>
            <div class="row">
                <div class="col-md-4 mb-3" th:each="t : ${viajes}">
                    <div class="card h-100">
                        <img th:src="@{/images/{img}(img=${t.imagen})}" 
                             class="card-img-top" 
                             style="height: 200px; object-fit: cover;"
                             onerror="this.src='https://via.placeholder.com/300x200?text=Sin+Imagen'"/>
                        <div class="card-body">
                            <h5 class="card-title" th:text="${t.nombre}">Viaje</h5>
                            <p class="card-text" th:text="${t.descripcion}">Descripción</p>
                            <p class="card-text">
                                <strong>Costo:</strong> <span th:text="${'$' + t.costo}"></span><br/>
                                <strong>Categoría:</strong> <span th:text="${t.categoria != null ? t.categoria.nombre : 'Sin categoría'}"></span>
                            </p>
                            <a th:href="@{/trips/view/{id}(id=${t.id})}" class="btn btn-primary">Ver más</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>