<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8">
    <title>AppTrip - Inicio</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: Arial, Helvetica, sans-serif;
            background-color: #f5f5f5;
        }

        .navbar {
            background-color: #1e3a5f;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 40px;
            flex-wrap: wrap;
        }
        .nav-left {
            display: flex;
            align-items: center;
            gap: 40px;
            flex-wrap: wrap;
        }
        .logo {
            color: white;
            font-size: 1.3rem;
            font-weight: bold;
        }
        .nav-links {
            display: flex;
            gap: 25px;
        }
        .nav-links a {
            color: white;
            text-decoration: none;
            font-size: 0.95rem;
        }
        .nav-right {
            display: flex;
            gap: 15px;
            align-items: center;
        }
        .btn-ingresar {
            background: transparent;
            border: 1px solid white;
            color: white;
            padding: 6px 18px;
            border-radius: 20px;
            text-decoration: none;
            font-size: 0.9rem;
            cursor: pointer;
        }
        .btn-registrarse {
            background: white;
            border: none;
            color: #1e3a5f;
            padding: 6px 18px;
            border-radius: 20px;
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: bold;
            cursor: pointer;
        }

        .container {
            max-width: 900px;
            margin: 0 auto;
            padding: 40px 20px;
            text-align: center;
        }

        .hero h1 {
            color: #2c7a4d;
            font-size: 2rem;
            margin-bottom: 15px;
            font-weight: bold;
        }
        .hero h2 {
            font-size: 1.6rem;
            color: #333;
            margin-bottom: 10px;
            font-weight: bold;
        }
        .hero p {
            color: #666;
            font-size: 1rem;
            margin-bottom: 30px;
        }

        .search-bar {
            display: flex;
            justify-content: center;
            gap: 10px;
            flex-wrap: wrap;
            margin-bottom: 50px;
        }
        .search-bar input {
            padding: 10px 15px;
            border: 1px solid #ccc;
            border-radius: 5px;
            width: 220px;
            font-size: 0.9rem;
        }
        .search-bar select {
            padding: 10px 15px;
            border: 1px solid #ccc;
            border-radius: 5px;
            background: white;
            font-size: 0.9rem;
        }
        .search-bar button {
            background-color: #3182ce;
            color: white;
            border: none;
            padding: 10px 25px;
            border-radius: 5px;
            cursor: pointer;
            font-size: 0.9rem;
            font-weight: bold;
        }
        .search-bar button:hover {
            background-color: #2c5282;
        }

        .section-title {
            font-size: 1.3rem;
            font-weight: bold;
            color: #333;
            margin-bottom: 30px;
            letter-spacing: 1px;
        }

        .trips-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 25px;
            justify-content: center;
        }
        .trip-card {
            background: white;
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            width: 280px;
            border: 1px solid #e0e0e0;
            text-align: left;
        }
        .card-img {
            width: 100%;
            height: 150px;
            object-fit: cover;
            background-color: #e0e0e0;
        }
        .card-body {
            padding: 12px;
        }
        .card-category {
            color: #3182ce;
            font-size: 0.7rem;
            font-weight: bold;
            margin-bottom: 5px;
        }
        .card-title {
            font-size: 1rem;
            font-weight: bold;
            margin-bottom: 5px;
            color: #333;
        }
        .card-img-label {
            color: #888;
            font-size: 0.65rem;
            margin-bottom: 5px;
        }
        .card-date {
            color: #888;
            font-size: 0.65rem;
            margin-bottom: 8px;
        }
        .card-description {
            color: #555;
            font-size: 0.75rem;
            line-height: 1.4;
            margin-bottom: 10px;
        }
        .btn-detail {
            color: #3182ce;
            text-decoration: none;
            font-size: 0.75rem;
            font-weight: bold;
        }
        .alert-info {
            background: #e3f2fd;
            color: #1e3a5f;
            padding: 15px;
            border-radius: 8px;
            text-align: center;
        }
        .alert-info a {
            color: #3182ce;
            text-decoration: none;
        }

        footer {
            text-align: center;
            margin-top: 50px;
            padding: 20px;
            color: #aaa;
            font-size: 0.7rem;
            border-top: 1px solid #ddd;
        }
        @media (max-width: 768px) {
            .navbar {
                flex-direction: column;
                gap: 15px;
                text-align: center;
            }
            .nav-left {
                justify-content: center;
            }
            .hero h2 {
                font-size: 1.2rem;
            }
        }
    </style>
</head>
<body>


    <div class="navbar">
        <div class="nav-left">
            <div class="logo">TripApp</div>
            <div class="nav-links">
                <a th:href="@{/}">Inicio</a>
                <a th:href="@{/trips/list}">Ver Viajes</a>
                <a th:href="@{/categorias/index}">Categorías</a>
            </div>
        </div>
        <div class="nav-right">
            <a href="#" class="btn-ingresar">Ingresar</a>
            <a href="#" class="btn-registrarse">Registrarse</a>
        </div>
    </div>


    <div class="container">
        <div class="hero">
            <h1>¡Bienvenido a AppTrip!</h1>
            <h2>Encuentra los mejores Trips en El Salvador.</h2>
            <p>Puedes buscar por descripción y categoría</p>
        </div>

        <div class="search-bar">
            <input type="text" placeholder="Escriba una búsqueda" id="searchInput">
            <select id="categorySelect">
                <option value="">Todas las categorías</option>
                <option th:each="cat : ${categorias}" th:value="${cat.id}" th:text="${cat.nombre}"></option>
            </select>
            <button onclick="filtrarTrips()">Buscar</button>
        </div>

        <div class="section-title">TRIPS DESTACADOS</div>

        <div th:if="${viajes != null and !viajes.empty}">
            <div class="trips-grid" id="tripsGrid">
                <div class="trip-card" th:each="t : ${viajes}" 
                     th:data-nombre="${t.nombre}" 
                     th:data-categoria="${t.categoria != null ? t.categoria.id : ''}">
                    <img th:src="@{/images/{img}(img=${t.imagen})}" 
                         class="card-img" 
                         th:alt="${t.nombre}"
                         onerror="this.src='https://via.placeholder.com/280x150?text=Sin+Imagen'"/>
                    <div class="card-body">
                        <div class="card-category" th:text="${t.categoria != null ? t.categoria.nombre : 'Sin categoría'}">Categoría</div>
                        <div class="card-title" th:text="${t.nombre}">Nombre del viaje</div>
                        <div class="card-img-label">Imagen del viaje</div>
                        <div class="card-date" th:text="${'Publicado: ' + #dates.format(t.fecha, 'EEE MMM dd HH:mm:ss zzz yyyy')}">Fecha</div>
                        <div class="card-description" th:text="${t.descripcion != null ? t.descripcion.length() > 100 ? t.descripcion.substring(0,100) + '...' : t.descripcion : 'Sin descripción'}">Descripción</div>
                        <a th:href="@{/trips/view/{id}(id=${t.id})}" class="btn-detail">Ver detalles →</a>
                    </div>
                </div>
            </div>
        </div>

        <div th:if="${viajes == null or viajes.empty}" class="alert-info">
            No hay viajes registrados. <a th:href="@{/trips/create}">Crea tu primer viaje</a>
        </div>

        <footer>
            <p>© 2026 TripApp, Inc. | WebApp · Términos · Privacidad</p>
        </footer>
    </div>

    <script>
        function filtrarTrips() {
            const searchText = document.getElementById('searchInput').value.toLowerCase();
            const categoryId = document.getElementById('categorySelect').value;
            const cards = document.querySelectorAll('#tripsGrid .trip-card');
            
            cards.forEach(card => {
                const nombre = card.getAttribute('data-nombre')?.toLowerCase() || '';
                const descripcion = card.querySelector('.card-description')?.innerText.toLowerCase() || '';
                const categoria = card.getAttribute('data-categoria') || '';
                
                const matchSearch = searchText === '' || nombre.includes(searchText) || descripcion.includes(searchText);
                const matchCategory = categoryId === '' || categoria === categoryId;
                
                if (matchSearch && matchCategory) {
                    card.style.display = '';
                } else {
                    card.style.display = 'none';
                }
            });
        }
    </script>
</body>
</html>