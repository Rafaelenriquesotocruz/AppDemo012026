<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8">
    <title>AppTrip - Inicio</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f5f5f5;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }
        .container {
            max-width: 800px;
            width: 100%;
            margin: 0 auto;
            padding: 40px 20px;
            text-align: center;
        }
        h1 {
            font-size: 2rem;
            font-weight: bold;
            color: #333;
            margin-bottom: 15px;
        }
        h2 {
            font-size: 1.2rem;
            font-weight: normal;
            color: #555;
            margin-bottom: 10px;
        }
        p {
            color: #777;
            margin-bottom: 30px;
        }
        .search-bar {
            display: flex;
            justify-content: center;
            gap: 10px;
            flex-wrap: wrap;
            margin-bottom: 40px;
        }
        .search-bar input {
            padding: 10px 15px;
            border: 1px solid #ccc;
            border-radius: 5px;
            width: 220px;
            font-size: 0.9rem;
        }
        .search-bar select {
            padding: 10px 15px;
            border: 1px solid #ccc;
            border-radius: 5px;
            background: white;
            font-size: 0.9rem;
        }
        .search-bar button {
            background: #007bff;
            color: white;
            border: none;
            padding: 10px 25px;
            border-radius: 5px;
            cursor: pointer;
            font-size: 0.9rem;
        }
        .search-bar button:hover {
            background: #0056b3;
        }
        .trips-destacados {
            margin-top: 20px;
        }
        .trips-destacados h3 {
            font-size: 1.1rem;
            font-weight: bold;
            color: #333;
            margin-bottom: 30px;
        }
        footer {
            margin-top: 60px;
            padding-top: 20px;
            border-top: 1px solid #ddd;
            color: #999;
            font-size: 0.75rem;
        }
        .alert-info {
            background-color: #e7f3ff;
            color: #0066cc;
            padding: 15px;
            border-radius: 5px;
            margin: 20px 0;
        }
        .alert-info a {
            color: #0066cc;
            text-decoration: none;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>¡Bienvenido a AppTrip!</h1>
        <h2>Encuentra los mejores Trips en El Salvador</h2>
        <p>Puedes buscar por descripción y categoría.</p>

        <div class="search-bar">
            <input type="text" placeholder="Escriba una búsqueda" id="searchInput">
            <select id="categorySelect">
                <option value="">Todas las categorías</option>
                <option th:each="cat : ${categorias}" th:value="${cat.id}" th:text="${cat.nombre}"></option>
            </select>
            <button onclick="filtrarTrips()">Buscar</button>
        </div>

        <div class="trips-destacados">
            <h3>TRIPS DESTACADOS</h3>

            <div th:if="${viajes != null and !viajes.empty}" id="tripsGrid">
                <div th:each="t : ${viajes}" style="background: white; border: 1px solid #ddd; border-radius: 8px; padding: 15px; margin-bottom: 15px; text-align: left;" 
                     th:data-nombre="${t.nombre}" th:data-categoria="${t.categoria != null ? t.categoria.id : ''}">
                    <strong style="color: #007bff;" th:text="${t.categoria != null ? t.categoria.nombre : 'Sin categoría'}">Categoría</strong>
                    <h4 style="margin: 10px 0 5px;" th:text="${t.nombre}">Nombre del viaje</h4>
                    <div style="color: #888; font-size: 0.75rem; margin-bottom: 10px;" th:text="${'Publicado: ' + #dates.format(t.fecha, 'EEE MMM dd HH:mm:ss zzz yyyy')}">Fecha</div>
                    <p style="color: #555; font-size: 0.85rem;" th:text="${t.descripcion != null ? t.descripcion.length() > 150 ? t.descripcion.substring(0,150) + '...' : t.descripcion : 'Sin descripción'}">Descripción</p>
                    <a th:href="@{/trips/view/{id}(id=${t.id})}" style="color: #007bff; text-decoration: none;">Ver detalles →</a>
                </div>
            </div>

            <div th:if="${viajes == null or viajes.empty}" class="alert-info">
                No hay viajes registrados. <a th:href="@{/trips/create}">Crea tu primer viaje</a>
            </div>
        </div>

        <footer>
            <p>© 2026 TripApp, Inc. | WebApp - Términos - Privacidad</p>
        </footer>
    </div>

    <script>
        function filtrarTrips() {
            const searchText = document.getElementById('searchInput').value.toLowerCase();
            const categoryId = document.getElementById('categorySelect').value;
            const cards = document.querySelectorAll('#tripsGrid > div');
            
            cards.forEach(card => {
                const nombre = card.getAttribute('data-nombre')?.toLowerCase() || '';
                const descripcion = card.querySelector('p')?.innerText.toLowerCase() || '';
                const categoria = card.getAttribute('data-categoria') || '';
                
                const matchSearch = searchText === '' || nombre.includes(searchText) || descripcion.includes(searchText);
                const matchCategory = categoryId === '' || categoria === categoryId;
                
                if (matchSearch && matchCategory) {
                    card.style.display = '';
                } else {
                    card.style.display = 'none';
                }
            });
        }
    </script>
</body>
</html>